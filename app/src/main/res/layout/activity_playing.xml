<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_playing_page">

    <FrameLayout
        android:id="@+id/flBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/llContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            android:id="@+id/titleLayout"
            layout="@layout/activity_playing_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constrainedWidth="true"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="@dimen/page_content_max_width" />

        <TextView
            android:id="@+id/tvListenTogetherStatus"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_playing_status_light"
            android:gravity="center"
            android:maxWidth="260dp"
            android:paddingHorizontal="16dp"
            android:singleLine="true"
            android:textColor="@color/common_text_h1_color"
            android:textSize="12dp"
            android:visibility="gone"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/titleLayout" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/flCoverLrc"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toTopOf="@+id/controlLayout"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvListenTogetherStatus"
            app:layout_constraintWidth_max="@dimen/page_content_max_width">

            <me.wcy.music.widget.AlbumCoverView
                android:id="@+id/albumCoverView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible" />

            <androidx.constraintlayout.widget.Group
                android:id="@+id/lrcLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:constraint_referenced_ids="volumeLayout,lrcView,ivLrcTopMask,ivLrcBottomMask" />

            <include
                android:id="@+id/volumeLayout"
                layout="@layout/activity_playing_volume" />

            <me.wcy.lrcview.LrcView
                android:id="@+id/lrcView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/volumeLayout"
                app:lrcAnimationDuration="420"
                app:lrcCurrentTextColor="@color/playing_on_surface"
                app:lrcDividerHeight="24dp"
                app:lrcNormalTextColor="@color/playing_on_surface_variant"
                app:lrcNormalTextSize="15sp"
                app:lrcPadding="40dp"
                app:lrcTextSize="18sp"
                app:lrcTimelineColor="?attr/colorPrimary"
                app:lrcTimelineTextColor="?attr/colorPrimary" />

            <ImageView
                android:id="@+id/ivLrcTopMask"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="@drawable/bg_lrc_top_fade"
                app:layout_constraintTop_toTopOf="@+id/lrcView" />

            <ImageView
                android:id="@+id/ivLrcBottomMask"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="@drawable/bg_lrc_bottom_fade"
                app:layout_constraintBottom_toBottomOf="@+id/lrcView" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <include
            android:id="@+id/controlLayout"
            layout="@layout/activity_playing_control"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="20dp"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintWidth_max="@dimen/page_content_max_width" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
